{
  "version": 2,
  "builds": [
    {
      "src": "index.php",
      "use": "vercel-php@0.7.2"
    },
    {
      "src": "contact-handler.php",
      "use": "vercel-php@0.7.2"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/contact-handler.php",
      "dest": "/contact-handler.php"
    },
    {
      "src": "/(.*)",
      "dest": "/index.php"
    }
  ]
}
